@model List<CatalogoApp.Domain.Models.Item>
@{
    ViewData["Title"] = "Catálogo de Canciones";
}

<h2 class="mb-4">🎵 Catálogo de Canciones</h2>

<div class="row row-cols-1 row-cols-md-3 g-4">
    @foreach (var item in Model)
    {
        <div class="col">
            <div class="card h-100 shadow-sm">
                <div class="card-body">
                    <h5 class="card-title">🎵 @item.Titulo</h5>
                    <h6 class="text-muted">@item.Consola</h6>
                    <p class="card-text small">@item.Descripcion</p>
                    <span class="badge bg-secondary">🎸 @item.Genero</span>
                    <span class="badge bg-primary ms-1">📅 @item.Ano</span>
                </div>
                <div class="card-footer">
                    <a asp-action="Detalle" asp-route-id="@item.Id" class="btn btn-primary btn-sm w-100">
                        Ver detalle
                    </a>
                </div>
            </div>
        </div>
    }
</div>s